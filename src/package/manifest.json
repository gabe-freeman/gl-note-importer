{
  "manifest_version": 3,
  "name": "Notes Transfer for Gospel Library",
  "description": "A browser extension for sharing notes across accounts in Gospel Library.",
  "version": "1.0.0",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["https://*.churchofjesuschrist.org/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://*.churchofjesuschrist.org/*"]
    }
  ]
}